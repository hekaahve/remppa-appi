# ─── Google OAuth (kirjautuminen) ─────────────────────────────────────────────
# Lähde: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generoi: openssl rand -base64 32
# Vercelissä: aseta AUTH_SECRET (sama arvo)
NEXTAUTH_SECRET=
# Kehitysympäristö: http://localhost:3000
# Tuotanto: https://your-app.vercel.app
NEXTAUTH_URL=

# ─── Google Sheets ────────────────────────────────────────────────────────────
# Sheets-tiedoston ID URL:sta: docs.google.com/spreadsheets/d/[ID]/edit
GOOGLE_SHEETS_ID=

# ─── Service Account (Sheets API) ─────────────────────────────────────────────
# Lähde: Google Cloud Console → IAM & Admin → Service Accounts → Keys → JSON
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# TÄRKEÄÄ – Vercelissä:
#   Kopioi private key JSON-tiedostosta (koko -----BEGIN ... END----- lohko)
#   ja liitä Vercelin env var -kenttään sellaisenaan (monirivisenä).
#   Vercel tallentaa sen automaattisesti oikein.
# Kehitysympäristössä (.env.local): käytä \n-escapattua yksirivismuotoa.
GOOGLE_PRIVATE_KEY=
